{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SuperTools",
  "version": "0.1.0",
  "identifier": "com.supertools.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SuperTools",
        "width": 1440,
        "height": 960,
        "minWidth": 1160,
        "minHeight": 760,
        "resizable": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all",
    "externalBin": [
      "binaries/cwebp"
    ]
  }
}
